<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.proj4.mapper.AdminMapper">
    
    <select id="selectAll" resultType="com.proj4.entity.Admin">
        SELECT * FROM ADMIN
        <where><if test="name != null">name like concat('%',#{name},'%')</if></where>
    </select>

    <insert id="insert" parameterType="com.proj4.entity.Admin">
        INSERT INTO `ADMIN` (account,password,role,name,avatar)
        values (#{account}, #{password}, #{role},#{name},#{avatar})
    </insert>

    <update id="updateById" parameterType="com.proj4.entity.Admin">
        UPDATE `ADMIN`
            set account = #{account},
                password = #{password},
                role = #{role},
                name = #{name},
                avatar = #{avatar}
        WHERE id = #{id}
    </update>

</mapper>